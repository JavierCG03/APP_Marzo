<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarslineApp.Views.Buscador.VerReportePage"
             BackgroundColor="Transparent"
             Shell.NavBarIsVisible="False"
             Title="Reporte de Orden">

    <Grid RowDefinitions="*,60"
          ColumnDefinitions="*">

        <!-- ═══ VISOR PDF ═══ -->
        <Grid Grid.Row="0"
              Grid.Column="0"
              Margin="12">

            <WebView x:Name="pdfview"
                     VerticalOptions="FillAndExpand"
                     HorizontalOptions="FillAndExpand" />

            <!-- Indicador de carga -->
            <Grid x:Name="LoadingIndicator"
                  IsVisible="False"
                  BackgroundColor="#80000000"
                  VerticalOptions="FillAndExpand"
                  HorizontalOptions="FillAndExpand">

                <VerticalStackLayout
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    Spacing="15">

                    <ActivityIndicator
                        IsRunning="True"
                        Color="#00D4FF"
                        WidthRequest="50"
                        HeightRequest="50"/>

                    <Label
                        Text="Cargando PDF..."
                        TextColor="White"
                        FontSize="16"
                        HorizontalTextAlignment="Center"/>

                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- ═══ FOOTER CON CONTROLES ═══ -->
        <Grid Grid.Row="1"
              Margin="0,0,0,20"
              Grid.Column="0"
              Padding="10,0"
              ColumnDefinitions="50,50,50">

            <!-- Compartir -->
            <ImageButton Grid.Column="0"
                         Source="compartir.png"
                         BackgroundColor="Transparent"
                         WidthRequest="40"
                         HeightRequest="40"
                         HorizontalOptions="Center"
                         VerticalOptions="Center"
                         Clicked="OnShareClicked" />

            <!-- Descargar -->
            <ImageButton Grid.Column="1"
                         Source="descargar.png"
                         BackgroundColor="Transparent"
                         WidthRequest="40"
                         HeightRequest="40"
                         HorizontalOptions="Center"
                         VerticalOptions="Center"
                         Clicked="OnDownloadClicked" />

            <!-- Abrir con... -->
            <ImageButton Grid.Column="2"
                         Source="pdf.png"
                         BackgroundColor="Transparent"
                         WidthRequest="40"
                         HeightRequest="40"
                         HorizontalOptions="Center"
                         VerticalOptions="Center"
                         Clicked="OnOpenWithClicked" />

        </Grid>
    </Grid>
</ContentPage>
