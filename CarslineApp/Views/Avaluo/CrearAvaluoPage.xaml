<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CarslineApp.ViewModels"
             x:Class="CarslineApp.Views.Avaluo.CrearAvaluoPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             Title="Crear Avalúo">

    <Grid RowDefinitions="Auto,*,Auto" Padding="0">

        <!-- ══════════════════════════════════════════════════ -->
        <!-- HEADER — título dinámico por paso                  -->
        <!-- ══════════════════════════════════════════════════ -->
        <Frame Grid.Row="0"
               BackgroundColor="#B00000"
               Padding="20"
               Margin="0"
               CornerRadius="0"
               HasShadow="True">
            <Label Text="{Binding TituloPaso}"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"/>
        </Frame>

        <!-- ══════════════════════════════════════════════════ -->
        <!-- CONTENIDO                                          -->
        <!-- ══════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">

                <!-- =========================================== -->
                <!-- PASO 1: DATOS DEL CLIENTE                   -->
                <!-- =========================================== -->
                <VerticalStackLayout Spacing="15"
                                     IsVisible="{Binding MostrarPaso1}">

                    <Label Text="👤 Información del cliente"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#404040"/>

                    <!-- Nombre -->
                    <Grid ColumnDefinitions="110,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                               Text="Nombre:"
                               FontSize="14"
                               FontAttributes="Italic"
                               VerticalOptions="Center"
                               TextColor="#B00000"/>
                        <Entry Grid.Column="1"
                               Text="{Binding NombreCompleto}"
                               Placeholder="Nombre Completo *"
                               MaxLength="100"/>
                    </Grid>

                    <!-- Tipo cliente -->
                    <Grid ColumnDefinitions="110,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                               Text="Tipo:"
                               FontSize="14"
                               FontAttributes="Italic"
                               VerticalOptions="Center"
                               TextColor="#B00000"/>
                        <Picker Grid.Column="1"
                                SelectedItem="{Binding TipoCliente}"
                                ItemsSource="{x:Static vm:CrearAvaluoViewModel.TiposCliente}"
                                HorizontalOptions="Fill"/>
                    </Grid>

                    <!-- Teléfono 1 -->
                    <Grid ColumnDefinitions="110,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                               Text="Teléfono 1:"
                               FontSize="14"
                               FontAttributes="Italic"
                               VerticalOptions="Center"
                               TextColor="#B00000"/>
                        <Entry Grid.Column="1"
                               Text="{Binding Telefono1}"
                               Placeholder="10 dígitos *"
                               MaxLength="10"
                               Keyboard="Numeric"/>
                    </Grid>

                    <!-- Teléfono 2 -->
                    <Grid ColumnDefinitions="110,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                               Text="Teléfono 2:"
                               FontSize="14"
                               FontAttributes="Italic"
                               VerticalOptions="Center"
                               TextColor="#B00000"/>
                        <Entry Grid.Column="1"
                               Text="{Binding Telefono2}"
                               Placeholder="Opcional"
                               MaxLength="10"
                               Keyboard="Numeric"/>
                    </Grid>





                    <!-- Mensaje de error -->
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#B00000"
                           FontSize="13"
                           FontAttributes="Bold"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
                           HorizontalOptions="Center"
                           Margin="0,10"/>

                    <!-- Botón Siguiente -->
                    <Button Text="SIGUIENTE ▶"
                            Command="{Binding SiguienteCommand}"
                            BackgroundColor="#B00000"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="55"
                            FontAttributes="Bold"
                            FontSize="16"/>

                </VerticalStackLayout>

                <!-- =========================================== -->
                <!-- PASO 2: DATOS DEL VEHÍCULO                  -->
                <!-- =========================================== -->
                <VerticalStackLayout Spacing="15"
                                     IsVisible="{Binding MostrarPaso2}">

                    <!-- ── VIN ──────────────────────────────── -->
                    <Label Text="🔑 VIN del vehículo"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#404040"/>

                    <Label Text="Ingresa el VIN de 17 caracteres"
                           FontSize="13"
                           TextColor="#666"
                           Margin="0,-10,0,0"/>


                    <Entry Text="{Binding VIN}"
                           Placeholder="17 caracteres *"
                           MaxLength="17"
                           TextTransform="Uppercase"
                           TextChanged="OnVinTextChanged"/>

                    <!-- Panel de estado VIN -->
                    <Frame IsVisible="{Binding MostrarEstadoVin}"
                           BackgroundColor="{Binding ColorEstadoVin}"
                           BorderColor="{Binding ColorBordeEstadoVin}"
                           Padding="12"
                           HasShadow="False"
                           CornerRadius="8">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <ActivityIndicator Grid.Column="0"
                                               IsRunning="{Binding VinDecodificando}"
                                               IsVisible="{Binding VinDecodificando}"
                                               Color="#B00000"
                                               WidthRequest="20"
                                               HeightRequest="20"
                                               VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   Text="{Binding VinMensajeDecodificacion}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{Binding ColorTextoEstadoVin}"
                                   VerticalOptions="Center"
                                   LineBreakMode="WordWrap"/>
                        </Grid>
                    </Frame>

                    <BoxView HeightRequest="2" BackgroundColor="#E0E0E0" Margin="0,5"/>

                    <!-- ── MARCA con autocompletado ─────────── -->
                    <Grid ColumnDefinitions="70,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                               Text="Marca:"
                               FontSize="14"
                               FontAttributes="Italic"
                               VerticalOptions="Start"
                               Margin="0,10,0,0"
                               TextColor="#B00000"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="0">
                            <Entry Text="{Binding BusquedaMarca}"
                                   Placeholder="Escribe o toca para ver marcas"
                                   TextChanged="OnMarcaTextChanged">
                                <Entry.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding AbrirSugerenciasMarcaCommand}"/>
                                </Entry.GestureRecognizers>
                            </Entry>
                            <Frame IsVisible="{Binding MostrarSugerenciasMarca}"
                                   BorderColor="#B00000"
                                   BackgroundColor="White"
                                   Padding="0"
                                   HasShadow="True"
                                   CornerRadius="6"
                                   Margin="0,-2,0,0">
                                <CollectionView ItemsSource="{Binding MarcasFiltradas}"
                                               SelectionMode="None"
                                               MaximumHeightRequest="200">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="14,10" BackgroundColor="White">
                                                <Grid.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SeleccionarMarcaCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Grid.GestureRecognizers>
                                                <Label Text="{Binding .}"
                                                       FontSize="14"
                                                       TextColor="#212121"/>
                                                <BoxView HeightRequest="1" Color="#F0F0F0"
                                                         VerticalOptions="End"/>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </Frame>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- ── MODELO con autocompletado ────────── -->
                    <Grid ColumnDefinitions="70,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                               Text="Modelo:"
                               FontSize="14"
                               FontAttributes="Italic"
                               VerticalOptions="Start"
                               Margin="0,10,0,0"
                               TextColor="#B00000"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="0">
                            <Entry Text="{Binding BusquedaModelo}"
                                   Placeholder="Selecciona la marca primero"
                                   TextChanged="OnModeloTextChanged">
                                <Entry.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding AbrirSugerenciasModeloCommand}"/>
                                </Entry.GestureRecognizers>
                            </Entry>
                            <Frame IsVisible="{Binding MostrarSugerenciasModelo}"
                                   BorderColor="#B00000"
                                   BackgroundColor="White"
                                   Padding="0"
                                   HasShadow="True"
                                   CornerRadius="6"
                                   Margin="0,-2,0,0">
                                <CollectionView ItemsSource="{Binding ModelosFiltrados}"
                                               SelectionMode="None"
                                               MaximumHeightRequest="200">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="14,10" BackgroundColor="White">
                                                <Grid.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SeleccionarModeloCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Grid.GestureRecognizers>
                                                <Label Text="{Binding .}"
                                                       FontSize="14"
                                                       TextColor="#212121"/>
                                                <BoxView HeightRequest="1" Color="#F0F0F0"
                                                         VerticalOptions="End"/>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </Frame>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- ── VERSIÓN con autocompletado ───────── -->
                    <Grid ColumnDefinitions="70,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                               Text="Versión:"
                               FontSize="14"
                               FontAttributes="Italic"
                               VerticalOptions="Start"
                               Margin="0,10,0,0"
                               TextColor="#B00000"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="0">
                            <Entry Text="{Binding BusquedaVersion}"
                                   Placeholder="Selecciona el modelo primero"
                                   TextChanged="OnVersionTextChanged">
                                <Entry.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding AbrirSugerenciasVersionCommand}"/>
                                </Entry.GestureRecognizers>
                            </Entry>
                            <Frame IsVisible="{Binding MostrarSugerenciasVersion}"
                                   BorderColor="#B00000"
                                   BackgroundColor="White"
                                   Padding="0"
                                   HasShadow="True"
                                   CornerRadius="6"
                                   Margin="0,-2,0,0">
                                <CollectionView ItemsSource="{Binding VersionesFiltradas}"
                                               SelectionMode="None"
                                               MaximumHeightRequest="200">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="14,10" BackgroundColor="White">
                                                <Grid.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SeleccionarVersionCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Grid.GestureRecognizers>
                                                <Label Text="{Binding .}"
                                                       FontSize="14"
                                                       TextColor="#212121"/>
                                                <BoxView HeightRequest="1" Color="#F0F0F0"
                                                         VerticalOptions="End"/>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </Frame>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- ── AÑO con autocompletado ────────────── -->
                    <Grid ColumnDefinitions="70,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                               Text="Año:"
                               FontSize="14"
                               FontAttributes="Italic"
                               VerticalOptions="Start"
                               Margin="0,10,0,0"
                               TextColor="#B00000"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="0">
                            <Entry Text="{Binding BusquedaAnio}"
                                   Placeholder="Selecciona la versión primero"
                                   Keyboard="Numeric"
                                   MaxLength="4"
                                   TextChanged="OnAnioTextChanged">
                                <Entry.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding AbrirSugerenciasAnioCommand}"/>
                                </Entry.GestureRecognizers>
                            </Entry>
                            <Frame IsVisible="{Binding MostrarSugerenciasAnio}"
                                   BorderColor="#B00000"
                                   BackgroundColor="White"
                                   Padding="0"
                                   HasShadow="True"
                                   CornerRadius="6"
                                   Margin="0,-2,0,0">
                                <CollectionView ItemsSource="{Binding AniosFiltrados}"
                                               SelectionMode="None"
                                               MaximumHeightRequest="150">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="14,10" BackgroundColor="White">
                                                <Grid.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SeleccionarAnioCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Grid.GestureRecognizers>
                                                <Label Text="{Binding .}"
                                                       FontSize="14"
                                                       TextColor="#212121"/>
                                                <BoxView HeightRequest="1" Color="#F0F0F0"
                                                         VerticalOptions="End"/>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </Frame>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- ── COLOR ─────────────────────────────── -->
                    <Grid ColumnDefinitions="70,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                               Text="Color:"
                               FontSize="14"
                               FontAttributes="Italic"
                               VerticalOptions="Center"
                               TextColor="#B00000"/>
                        <Entry Grid.Column="1"
                               Text="{Binding Color}"
                               Placeholder="Color del vehículo (opcional)"/>
                    </Grid>

                    <!-- ── PLACAS ─────────────────────────────── -->
                    <Grid ColumnDefinitions="70,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                               Text="Placas:"
                               FontSize="14"
                               FontAttributes="Italic"
                               VerticalOptions="Center"
                               TextColor="#B00000"/>
                        <Entry Grid.Column="1"
                               Text="{Binding Placas}"
                               Placeholder="Placas (S/P si no aplica)"
                               MaxLength="7"
                               TextTransform="Uppercase"/>
                    </Grid>

                    <!-- ── KILOMETRAJE ────────────────────────── -->
                    <Grid ColumnDefinitions="70,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                               Text="Km:"
                               FontSize="14"
                               FontAttributes="Italic"
                               VerticalOptions="Center"
                               TextColor="#B00000"/>
                        <Entry Grid.Column="1"
                               Text="{Binding Kilometraje}"
                               Placeholder="Kilometraje actual"
                               Keyboard="Numeric"/>
                    </Grid>
                    
                    <BoxView HeightRequest="2" BackgroundColor="#E0E0E0" Margin="0,5"/>

                    <Label Text="💰 Datos de la operación"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#404040"/>

                    <!-- Precio solicitado -->
                    <Grid ColumnDefinitions="130,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                               Text="Precio Solicitado:"
                               FontSize="14"
                               FontAttributes="Italic"
                               VerticalOptions="Center"
                               TextColor="#B00000"/>
                        <Entry Grid.Column="1"
                               Text="{Binding PrecioSolicitado}"
                               Placeholder="$0.00"
                               Keyboard="Numeric"/>
                    </Grid>

                    <!-- ── Vehículo a cuenta ──────────────────────────────────────── -->
                    <BoxView HeightRequest="2" BackgroundColor="#E0E0E0" Margin="0,5"/>

                    <Label Text="🔄 ¿Vehículo a cuenta?"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#404040"/>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding VehiculoACuenta}"
                                  Color="#B00000"
                                  VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="El cliente entregara su vehículo como parte de pago"
                               FontSize="14"
                               TextColor="#404040"
                               VerticalOptions="Center"
                               LineBreakMode="WordWrap"/>
                    </Grid>

                    <!-- Panel vehículo a cuenta — solo visible cuando IsChecked = true -->
                    <Frame IsVisible="{Binding MostrarPanelVehiculoCuenta}"
                           BackgroundColor="#FFF8E1"
                           BorderColor="#FF9800"
                           Padding="14"
                           HasShadow="False"
                           CornerRadius="10"
                           Margin="0,4,0,0">
                        <VerticalStackLayout Spacing="10">

                            <Label Text="¿Qué vehículo desea adquirir?"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#E65100"/>

                            <!-- Marca (cuenta) -->
                            <Grid ColumnDefinitions="70,*" ColumnSpacing="10">
                                <Label Grid.Column="0"
                                       Text="Marca:"
                                       FontSize="14"
                                       FontAttributes="Italic"
                                       VerticalOptions="Start"
                                       Margin="0,10,0,0"
                                       TextColor="#B00000"/>
                                <VerticalStackLayout Grid.Column="1" Spacing="0">
                                    <Entry Text="{Binding BusquedaCuentaMarca}"
                                           Placeholder="Escribe o toca para ver marcas"
                                           TextChanged="OnCuentaMarcaTextChanged">
                                        <Entry.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding AbrirSugerenciasCuentaMarcaCommand}"/>
                                        </Entry.GestureRecognizers>
                                    </Entry>
                                    <Frame IsVisible="{Binding MostrarSugerenciasCuentaMarca}"
                                           BorderColor="#B00000"
                                           BackgroundColor="White"
                                           Padding="0"
                                           HasShadow="True"
                                           CornerRadius="6"
                                           Margin="0,-2,0,0">
                                        <CollectionView ItemsSource="{Binding SugerenciasCuentaMarca}"
                                                       SelectionMode="None"
                                                       MaximumHeightRequest="180">
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Padding="14,10" BackgroundColor="White">
                                                        <Grid.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SeleccionarCuentaMarcaCommand}"
                                                                CommandParameter="{Binding .}"/>
                                                        </Grid.GestureRecognizers>
                                                        <Label Text="{Binding .}" FontSize="14" TextColor="#212121"/>
                                                        <BoxView HeightRequest="1" Color="#F0F0F0" VerticalOptions="End"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </Frame>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Modelo (cuenta) -->
                            <Grid ColumnDefinitions="70,*" ColumnSpacing="10">
                                <Label Grid.Column="0"
                                       Text="Modelo:"
                                       FontSize="14"
                                       FontAttributes="Italic"
                                       VerticalOptions="Start"
                                       Margin="0,10,0,0"
                                       TextColor="#B00000"/>
                                <VerticalStackLayout Grid.Column="1" Spacing="0">
                                    <Entry Text="{Binding BusquedaCuentaModelo}"
                                           Placeholder="Selecciona la marca primero"
                                           TextChanged="OnCuentaModeloTextChanged">
                                        <Entry.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding AbrirSugerenciasCuentaModeloCommand}"/>
                                        </Entry.GestureRecognizers>
                                    </Entry>
                                    <Frame IsVisible="{Binding MostrarSugerenciasCuentaModelo}"
                                           BorderColor="#B00000"
                                           BackgroundColor="White"
                                           Padding="0"
                                           HasShadow="True"
                                           CornerRadius="6"
                                           Margin="0,-2,0,0">
                                        <CollectionView ItemsSource="{Binding SugerenciasCuentaModelo}"
                                                       SelectionMode="None"
                                                       MaximumHeightRequest="180">
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Padding="14,10" BackgroundColor="White">
                                                        <Grid.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SeleccionarCuentaModeloCommand}"
                                                                CommandParameter="{Binding .}"/>
                                                        </Grid.GestureRecognizers>
                                                        <Label Text="{Binding .}" FontSize="14" TextColor="#212121"/>
                                                        <BoxView HeightRequest="1" Color="#F0F0F0" VerticalOptions="End"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </Frame>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Versión (cuenta) -->
                            <Grid ColumnDefinitions="70,*" ColumnSpacing="10">
                                <Label Grid.Column="0"
                                       Text="Versión:"
                                       FontSize="14"
                                       FontAttributes="Italic"
                                       VerticalOptions="Start"
                                       Margin="0,10,0,0"
                                       TextColor="#B00000"/>
                                <VerticalStackLayout Grid.Column="1" Spacing="0">
                                    <Entry Text="{Binding BusquedaCuentaVersion}"
                                           Placeholder="Selecciona el modelo primero"
                                           TextChanged="OnCuentaVersionTextChanged">
                                        <Entry.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding AbrirSugerenciasCuentaVersionCommand}"/>
                                        </Entry.GestureRecognizers>
                                    </Entry>
                                    <Frame IsVisible="{Binding MostrarSugerenciasCuentaVersion}"
                                           BorderColor="#B00000"
                                           BackgroundColor="White"
                                           Padding="0"
                                           HasShadow="True"
                                           CornerRadius="6"
                                           Margin="0,-2,0,0">
                                        <CollectionView ItemsSource="{Binding SugerenciasCuentaVersion}"
                                                       SelectionMode="None"
                                                       MaximumHeightRequest="180">
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Padding="14,10" BackgroundColor="White">
                                                        <Grid.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SeleccionarCuentaVersionCommand}"
                                                                CommandParameter="{Binding .}"/>
                                                        </Grid.GestureRecognizers>
                                                        <Label Text="{Binding .}" FontSize="14" TextColor="#212121"/>
                                                        <BoxView HeightRequest="1" Color="#F0F0F0" VerticalOptions="End"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </Frame>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Año (cuenta) -->
                            <Grid ColumnDefinitions="70,*" ColumnSpacing="10">
                                <Label Grid.Column="0"
                                       Text="Año:"
                                       FontSize="14"
                                       FontAttributes="Italic"
                                       VerticalOptions="Start"
                                       Margin="0,10,0,0"
                                       TextColor="#B00000"/>
                                <VerticalStackLayout Grid.Column="1" Spacing="0">
                                    <Entry Text="{Binding BusquedaCuentaAnio}"
                                           Placeholder="Selecciona la versión primero"
                                           Keyboard="Numeric"
                                           MaxLength="4"
                                           TextChanged="OnCuentaAnioTextChanged">
                                        <Entry.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding AbrirSugerenciasCuentaAnioCommand}"/>
                                        </Entry.GestureRecognizers>
                                    </Entry>
                                    <Frame IsVisible="{Binding MostrarSugerenciasCuentaAnio}"
                                           BorderColor="#B00000"
                                           BackgroundColor="White"
                                           Padding="0"
                                           HasShadow="True"
                                           CornerRadius="6"
                                           Margin="0,-2,0,0">
                                        <CollectionView ItemsSource="{Binding SugerenciasCuentaAnio}"
                                                       SelectionMode="None"
                                                       MaximumHeightRequest="130">
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Padding="14,10" BackgroundColor="White">
                                                        <Grid.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SeleccionarCuentaAnioCommand}"
                                                                CommandParameter="{Binding .}"/>
                                                        </Grid.GestureRecognizers>
                                                        <Label Text="{Binding .}" FontSize="14" TextColor="#212121"/>
                                                        <BoxView HeightRequest="1" Color="#F0F0F0" VerticalOptions="End"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </Frame>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Resumen del vehículo construido -->
                            <Frame BackgroundColor="#FFF3E0"
                                   BorderColor="#FF9800"
                                   Padding="10"
                                   HasShadow="False"
                                   CornerRadius="8"
                                   IsVisible="{Binding VehiculoACuenta}">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <Label Grid.Column="0"
                                           Text="🚘"
                                           FontSize="18"
                                           VerticalOptions="Center"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding CuentaDeVehiculo}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#E65100"
                                           VerticalOptions="Center"
                                           LineBreakMode="WordWrap"/>
                                </Grid>
                            </Frame>

                        </VerticalStackLayout>
                    </Frame>

                    <!-- Mensaje de error -->
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#B00000"
                           FontSize="13"
                           FontAttributes="Bold"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
                           HorizontalOptions="Center"
                           Margin="0,10"/>

                    <!-- Botones Anterior / Guardar -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="◀ ANTERIOR"
                                Command="{Binding AnteriorCommand}"
                                BackgroundColor="#757575"
                                TextColor="White"
                                CornerRadius="10"
                                HeightRequest="55"
                                FontAttributes="Bold"/>

                        <Button Grid.Column="1"
                                Text="✓ GUARDAR"
                                Command="{Binding CrearAvaluoCommand}"
                                BackgroundColor="#4CAF50"
                                TextColor="White"
                                CornerRadius="10"
                                HeightRequest="55"
                                FontAttributes="Bold"
                                FontSize="16"/>
                    </Grid>

                </VerticalStackLayout>

                <!-- Indicador de carga global -->
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="#B00000"
                                   HeightRequest="40"
                                   HorizontalOptions="Center"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
