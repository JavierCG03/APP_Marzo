<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarslineApp.Views.ImagePreviewPage"
             BackgroundColor="#1A1A1A"
             Title="Vista Previa">

    <Grid RowDefinitions="56,*,60
          " ColumnDefinitions="*">

        <!-- ═══ HEADER PROFESIONAL ═══ -->
        <Grid Grid.Row="0"
              Grid.Column="0"
              BackgroundColor="#1A1A1A"
              Padding="0"
              ColumnDefinitions="50,*">

            <!-- Botón Atrás -->
            <Button Grid.Column="0"
                    Text="←"
                    FontSize="40"
                    TextColor="White"
                    BackgroundColor="Transparent"
                    Clicked="OnBackClicked"
                    Padding="5"
                    CornerRadius="25" />

            <!-- Título -->
            <Label Grid.Column="1"
                   Text="Vista Previa"
                   TextColor="White"
                   FontSize="20"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   HorizontalTextAlignment="Center" />

        </Grid> 

        <!-- ═══ CONTENEDOR DE IMAGEN ═══ -->
        <Grid x:Name="ImageContainer"
          Grid.Row="1"
          Margin="10"
          Grid.Column="0"
          BackgroundColor="#1A1A1A"
          Padding="0">
            
            <Image x:Name="PreviewImage"
                   Aspect="AspectFit"
                   HorizontalOptions="Center"
                   VerticalOptions="Center">
                <Image.GestureRecognizers>
                    <PinchGestureRecognizer PinchUpdated="OnPinchUpdated" />
                    <PanGestureRecognizer PanUpdated="OnPanUpdated" />
                    <TapGestureRecognizer NumberOfTapsRequired="2"
                                         Tapped="OnDoubleTap" />
                </Image.GestureRecognizers>
            </Image>

            <ActivityIndicator x:Name="LoadingIndicator"
                              IsRunning="False"
                              IsVisible="False"
                              Color="#00D4FF"
                              Scale="1.5" />
        </Grid>
        <!-- ═══ FOOTER CON CONTROLES ═══ -->
        <Grid Grid.Row="2"
          Margin="20,0,20,20"
          Grid.Column="0"
          Padding="10,0"
          ColumnDefinitions="50,50,*,50,Auto,50">
       
            <ImageButton Grid.Column="0"
                         Source="compartir.png"
                         BackgroundColor="Transparent"
                         WidthRequest="40"
                         HeightRequest="40"
                         Clicked="OnShareClicked">
            </ImageButton>
            
            <ImageButton Grid.Column="1"
                         Source="descargar.png"
                         BackgroundColor="Transparent"
                         WidthRequest="40"
                         HeightRequest="40"
                         Clicked="OnDownloadClicked">
            </ImageButton>

            <ImageButton Grid.Column="2"
                         Source="reset.png"
                         HorizontalOptions="End"
                         BackgroundColor="Transparent"
                         WidthRequest="40"
                         HeightRequest="40"
                         Clicked="OnResetClicked">
            </ImageButton>
            
            <ImageButton Grid.Column="3"
                         Source="zoom.png"
                         BackgroundColor="Transparent"
                         WidthRequest="40"
                         HeightRequest="40"
                         Clicked="OnZoomInClicked">
            </ImageButton>
            
            <Label Grid.Column="4"
                   x:Name="ZoomLabel"
                   Text="100%"
                   TextColor="#00D4FF"
                   FontSize="15"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   HorizontalOptions="Center" />

            <ImageButton Grid.Column="5"
                         Source="zoomout.png"
                         BackgroundColor="Transparent"
                         WidthRequest="40"
                         HeightRequest="40"
                         Clicked="OnZoomOutClicked">
            </ImageButton>

        </Grid>
    </Grid>
</ContentPage>