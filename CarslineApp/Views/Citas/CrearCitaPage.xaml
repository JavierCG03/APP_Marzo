<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarslineApp.Views.Citas.CrearCitaPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             Title="Crear Cita">
    
    <Grid RowDefinitions="Auto,*,Auto" Padding="0">

        <!-- HEADER CON TÃTULO DEL PASO -->
        <Frame Grid.Row="0" BackgroundColor="#B00000" Padding="20" Margin="0" CornerRadius="0" HasShadow="True">
            <Label Text="{Binding TituloPaso}"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"/>
        </Frame>

        <!-- CONTENIDO CON SCROLL -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">

                <!-- ====================================== -->
                <!-- PASO 1: DATOS DEL CLIENTE -->
                <!-- ====================================== -->
                <VerticalStackLayout Spacing="15" IsVisible="{Binding MostrarPaso1}">

                    <Label Text="ðŸ” Buscar Cliente por Nombre"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#404040"/>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Frame Grid.Column="0" BorderColor="Black" BackgroundColor="Transparent">
                        </Frame>
                        <Entry 
                               Text="{Binding NombreBusquedaCliente}"
                               Placeholder="Ej: Sebastian Aldama"
                               MaxLength="100"
                               ReturnCommand="{Binding BuscarClienteCommand}"/>

                        <ImageButton Grid.Column="1"
                                         Command="{Binding BuscarClienteCommand}"
                                         Source="buscar.png"
                                         BackgroundColor="Transparent"
                                         WidthRequest="50"
                                         HeightRequest="50"
                                         VerticalOptions="Center"/>
                    </Grid>

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#B00000"
                           FontSize="13"
                           FontAttributes="Bold"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
                           HorizontalOptions="Center"
                           Margin="0,10"/>

                    <!-- âœ… NUEVO: LISTA DE CLIENTES ENCONTRADOS -->
                    <Frame IsVisible="{Binding MostrarListaClientes}"
                           BackgroundColor="#E3F2FD"
                           Padding="10"
                           HasShadow="False"
                           BorderColor="#2196F3">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Selecciona el cliente correcto:"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#1976D2"/>

                            <CollectionView ItemsSource="{Binding ClientesEncontrados}"
                                            SelectionMode="None"
                                            MaximumHeightRequest="300">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Frame BackgroundColor="White"
                                               Padding="12"
                                               Margin="0,5"
                                               HasShadow="False"
                                               BorderColor="#BDBDBD">
                                            <Frame.GestureRecognizers>
                                                <TapGestureRecognizer 
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SeleccionarClienteCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Frame.GestureRecognizers>

                                            <VerticalStackLayout Spacing="3">
                                                <Label Text="{Binding NombreCompleto}"
                                                       FontSize="15"
                                                       FontAttributes="Bold"
                                                       TextColor="Black"/>
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                    <Label Grid.Column="0" 
                                                           Text="Tel:"
                                                           FontSize="12"
                                                           TextColor="#666"/>
                                                    <Label Grid.Column="1"
                                                           Text="{Binding TelefonoMovil}"
                                                           FontSize="12"
                                                           TextColor="#404040"/>
                                                </Grid>
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                    <Label Grid.Column="0" 
                                                           Text="RFC:"
                                                           FontSize="12"
                                                           TextColor="#666"/>
                                                    <Label Grid.Column="1"
                                                           Text="{Binding RFC}"
                                                           FontSize="12"
                                                           TextColor="#404040"/>
                                                </Grid>
                                            </VerticalStackLayout>
                                        </Frame>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Frame>

                    <BoxView HeightRequest="2" BackgroundColor="#E0E0E0" Margin="0,10"/>



                    <Label Text="Datos del Cliente"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#404040"/>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                                Text="Nombre:"
                                FontSize="14"
                                FontAttributes="Italic"
                                VerticalOptions="Center"
                                TextColor="#B00000"/>
                        <Entry Grid.Column="1"
                                Text="{Binding NombreCompleto}"
                                Placeholder="Nombre Completo *"
                                IsReadOnly="{Binding CamposClienteBloqueados}"/>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                                Text="RFC:"
                                FontSize="14"
                                FontAttributes="Italic"
                                VerticalOptions="Center"
                                TextColor="#B00000"/>
                        <Entry Grid.Column="1"
                                Text="{Binding RFC}"
                                MaxLength="13"
                                Placeholder="RFC *"
                                IsReadOnly="{Binding CamposClienteBloqueados}"/>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                                Text="TelÃ©fono Celular:"
                                FontSize="14"
                                FontAttributes="Italic"
                                VerticalOptions="Center"
                                TextColor="#B00000"/>
                        <Entry Grid.Column="1"
                                Text="{Binding TelefonoMovil}"
                                MaxLength="10"
                                Keyboard="Numeric"
                                Placeholder="NÃºmero Celular *"
                                IsReadOnly="{Binding CamposClienteBloqueados}"/>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                                Text="TelÃ©fono Casa:"
                                FontSize="14"
                                FontAttributes="Italic"
                                VerticalOptions="Center"
                                TextColor="#B00000"/>
                        <Entry Grid.Column="1"
                                Text="{Binding TelefonoCasa}"
                                MaxLength="10"
                                Keyboard="Numeric"
                                Placeholder="TelÃ©fono Casa (opcional)"
                                IsReadOnly="{Binding CamposClienteBloqueados}"/>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                                Text="Email:"
                                FontSize="14"
                                FontAttributes="Italic"
                                VerticalOptions="Center"
                                TextColor="#B00000"/>
                        <Entry Grid.Column="1"
                                Text="{Binding CorreoElectronico}"
                                Placeholder="Correo ElectrÃ³nico (opcional)"
                                IsReadOnly="{Binding CamposClienteBloqueados}"/>
                    </Grid>

                    <Label Text="DirecciÃ³n"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#404040"
                           Margin="0,10,0,0"/>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                                Text="Estado:"
                                FontSize="14"
                                FontAttributes="Italic"
                                VerticalOptions="Center"
                                TextColor="#B00000"/>
                        <Entry Grid.Column="1"
                                Text="{Binding Estado}"
                                Placeholder="Estado"
                                IsReadOnly="{Binding CamposClienteBloqueados}"/>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                                Text="Municipio:"
                                FontSize="14"
                                FontAttributes="Italic"
                                VerticalOptions="Center"
                                TextColor="#B00000"/>
                        <Entry Grid.Column="1"
                                Text="{Binding Municipio}"
                                Placeholder="Municipio"
                                IsReadOnly="{Binding CamposClienteBloqueados}"/>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                                Text="Colonia:"
                                FontSize="14"
                                FontAttributes="Italic"
                                VerticalOptions="Center"
                                TextColor="#B00000"/>
                        <Entry Grid.Column="1"
                                Text="{Binding Colonia}"
                                Placeholder="Colonia"
                                IsReadOnly="{Binding CamposClienteBloqueados}"/>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                                Text="Calle:"
                                FontSize="14"
                                FontAttributes="Italic"
                                VerticalOptions="Center"
                                TextColor="#B00000"/>
                        <Entry Grid.Column="1"
                                Text="{Binding Calle}"
                                Placeholder="Calle"
                                IsReadOnly="{Binding CamposClienteBloqueados}"/>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10">
                        <Label Grid.Column="2"
                                Text="CP:"
                                FontSize="14"
                                FontAttributes="Italic"
                                VerticalOptions="Center"
                                TextColor="#B00000"/>
                        <Entry Grid.Column="3"
                                Text="{Binding CodigoPostal}"
                                Keyboard="Numeric"
                                MaxLength="5"
                                Placeholder="#####"
                                IsReadOnly="{Binding CamposClienteBloqueados}"/>
                        <Label Grid.Column="0"
                                Text="Num. Ext:"
                                FontSize="14"
                                FontAttributes="Italic"
                                VerticalOptions="Center"
                                TextColor="#B00000"/>
                        <Entry Grid.Column="1"
                                Text="{Binding NumeroExterior}"
                                Keyboard="Numeric"
                                MaxLength="5"
                                Placeholder="#Ext"
                                IsReadOnly="{Binding CamposClienteBloqueados}"/>
                    </Grid>

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#B00000"
                           FontSize="13"
                           FontAttributes="Bold"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
                           HorizontalOptions="Center"
                           Margin="0,10"/>

                    <Button Text="{Binding TextoBotonCliente}"
                            Command="{Binding EditarGuardarClienteCommand}"
                            IsVisible="{Binding MostrarBotonEditarCliente}"
                            BackgroundColor="{Binding ColorBotonCliente}"
                            TextColor="White"
                            Margin="0,10,0,0"
                            HeightRequest="45"
                            FontAttributes="Bold"
                            CornerRadius="10"/>

                    <!-- BOTONES DE NAVEGACIÃ“N (SIN CAMBIOS) -->
                    <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="0" Padding="0">

                        <Button Grid.Column="0"
                    Text="â—€ ANTERIOR"
                    Command="{Binding AnteriorCommand}"
                    IsVisible="{Binding PasoActual, Converter={StaticResource GreaterThanOneConverter}}"
                    BackgroundColor="#757575"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="55"
                    FontAttributes="Bold"/>

                        <Button Grid.Column="1"
                    Text="SIGUIENTE â–¶"
                    Command="{Binding SiguienteCommand}"
                    IsVisible="{Binding MostrarBotonSiguiente}"
                    BackgroundColor="#B00000"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="55"
                    FontAttributes="Bold"/>
                    </Grid>

                </VerticalStackLayout>

                <!-- ====================================== -->
                <!-- PASO 2: DATOS DEL VEHÃCULO -->
                <!-- ====================================== -->
                <VerticalStackLayout Spacing="15" IsVisible="{Binding MostrarPaso2}">

                    <Label Text="ðŸ” Buscar VehÃ­culo por VIN"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#404040"/>

                    <Label Text="Ingresa los Ãºltimos 4 caracteres del VIN:"
                           FontSize="13"
                           TextColor="#666"
                           Margin="0,-10,0,0"/>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Frame Grid.Column="0" BorderColor="Black" BackgroundColor="Transparent">
                        </Frame>
                        <Entry 
                               Grid.Column="0"
                               Text="{Binding Ultimos4VIN}"
                               Placeholder="Ej: AB12"
                               MaxLength="4"
                               ReturnCommand="{Binding BuscarVehiculoCommand}"/>
                        <ImageButton Grid.Column="1"
                                         Command="{Binding BuscarVehiculoCommand}"
                                         Source="buscar.png"
                                         BackgroundColor="Transparent"
                                         WidthRequest="50"
                                         HeightRequest="50"
                                         VerticalOptions="Center"/>

                    </Grid>

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#B00000"
                           FontSize="13"
                           FontAttributes="Bold"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
                           HorizontalOptions="Center"
                           Margin="0,10"/>
                    <!-- âœ… NUEVO: LISTA DE VEHÃCULOS ENCONTRADOS -->
                    <Frame IsVisible="{Binding MostrarListaVehiculos}"
                           BackgroundColor="#E3F2FD"
                           Padding="10"
                           HasShadow="False"
                           BorderColor="#2196F3">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Selecciona el vehÃ­culo correcto:"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#1976D2"/>

                            <CollectionView ItemsSource="{Binding VehiculosEncontrados}"
                                            SelectionMode="None"
                                            MaximumHeightRequest="300">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Frame BackgroundColor="White"
                                               Padding="12"
                                               Margin="0,5"
                                               HasShadow="False"
                                               BorderColor="#BDBDBD">
                                            <Frame.GestureRecognizers>
                                                <TapGestureRecognizer 
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SeleccionarVehiculoCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Frame.GestureRecognizers>

                                            <VerticalStackLayout Spacing="3">
                                                <Label Text="{Binding VehiculoCompleto}"
                                                       FontSize="15"
                                                       FontAttributes="Bold"
                                                       TextColor="Black"/>
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                    <Label Grid.Column="0" 
                                                           Text="VIN:"
                                                           FontSize="12"
                                                           TextColor="#666"/>
                                                    <Label Grid.Column="1"
                                                           Text="{Binding VIN}"
                                                           FontSize="11"
                                                           TextColor="#404040"/>
                                                </Grid>
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                    <Label Grid.Column="0" 
                                                           Text="Cliente:"
                                                           FontSize="12"
                                                           TextColor="#666"/>
                                                    <Label Grid.Column="1"
                                                           Text="{Binding NombreCliente}"
                                                           FontSize="12"
                                                           TextColor="#404040"/>
                                                </Grid>
                                            </VerticalStackLayout>
                                        </Frame>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Frame>

                    <BoxView HeightRequest="2" BackgroundColor="#E0E0E0" Margin="0,10"/>

                    <!-- â”€â”€ Barra de cabecera con toggle y botÃ³n limpiar â”€â”€ -->
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">

                        <!-- BotÃ³n toggle que expande/colapsa los campos -->
                        <Frame Grid.Column="0"
                               BackgroundColor="Transparent"
                               BorderColor="Transparent"
                               Padding="0"
                               HorizontalOptions="Start">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleCamposVehiculoCommand}"/>
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                <Label Grid.Column="0"
                                       Text="{Binding IconoToggleCamposVehiculo}"
                                       FontSize="16"
                                       TextColor="#B00000"
                                       VerticalOptions="Center"/>
                                <Label Grid.Column="1"
                                       Text="{Binding TextoToggleCamposVehiculo}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="#404040"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Frame>

                        <!-- BotÃ³n editar/guardar (solo cuando hay vehÃ­culo cargado) -->
                        <ImageButton Grid.Column="1"
                            HorizontalOptions="End"
                            Source="{Binding ImagenBotonVehiculo}"
                            Command="{Binding EditarGuardarVehiculoCommand}"
                            IsVisible="{Binding MostrarBotonEditarVehiculo}"
                            BackgroundColor="Transparent"
                            HeightRequest="35"
                            WidthRequest="35"
                            CornerRadius="10"
                            ToolTipProperties.Text="Editar/Guardar placas vehÃ­culo"/>

                        <ImageButton Grid.Column="2"
                            HorizontalOptions="End"
                            Source="borrar.png"
                            Command="{Binding LimpiarVehiculoCommand}"
                            IsVisible="{Binding MostrarBotonLimpiarVehiculo}"
                            BackgroundColor="Transparent"
                            HeightRequest="35"
                            WidthRequest="35"
                            CornerRadius="10"
                            ToolTipProperties.Text="Borrar  datos de vehÃ­culo"/>
                    </Grid>

                    <!-- â”€â”€ Panel colapsable con todos los campos del vehÃ­culo â”€â”€ -->
                    <VerticalStackLayout IsVisible="{Binding MostrarCamposVehiculo}" Spacing="10">

                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                            <Label Grid.Column="0"
                               Text="VIN:"
                               FontSize="14"
                               FontAttributes="Italic"
                               VerticalOptions="Center"
                               TextColor="#B00000"/>
                            <Entry Grid.Column="1"
                               Text="{Binding VIN}"
                               Placeholder="17 caracteres"
                               MaxLength="17"
                               IsReadOnly="{Binding CamposVehiculoBloqueados}"/>

                            <ImageButton Grid.Column="2"
                                         Command="{Binding DecodificarVinManualCommand}"
                                         CommandParameter="{Binding VIN}"
                                         IsVisible="{Binding CamposVehiculoBloqueados, Converter={StaticResource InverseBoolConverter}}"
                                         Source="buscar.png"
                                         BackgroundColor="Transparent"
                                         WidthRequest="40"
                                         HeightRequest="40"
                                         VerticalOptions="Center"
                                         ToolTipProperties.Text="Decodificar VIN"/>

                        </Grid>

                        <!-- Panel de estado de decodificaciÃ³n VIN -->
                        <Frame IsVisible="{Binding MostrarEstadoVin}"
                           BackgroundColor="{Binding ColorEstadoVin}"
                           BorderColor="{Binding ColorBordeEstadoVin}"
                           CornerRadius="8"
                           Padding="12,8"
                           HasShadow="False"
                           Margin="0,-8,0,0">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <ActivityIndicator Grid.Column="0"
                                               IsRunning="{Binding VinDecodificando}"
                                               IsVisible="{Binding VinDecodificando}"
                                               Color="#E65100"
                                               WidthRequest="20"
                                               HeightRequest="20"
                                               VerticalOptions="Center"/>
                                <Label Grid.Column="1"
                                   Text="{Binding VinMensajeDecodificacion}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{Binding ColorTextoEstadoVin}"
                                   VerticalOptions="Center"
                                   LineBreakMode="WordWrap"/>
                            </Grid>
                        </Frame>

                        <!-- â•â• MARCA con autocompletado â•â• -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Grid.Column="0"
                               Text="Marca:"
                               FontSize="14"
                               FontAttributes="Italic"
                               VerticalOptions="Start"
                               Margin="0,10,0,0"
                               TextColor="#B00000"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="0">
                                <!-- Entry de bÃºsqueda -->
                                <Entry Text="{Binding BusquedaMarca}"
                                   Placeholder="Escribe o toca para ver marcas"
                                   IsReadOnly="{Binding CamposVehiculoBloqueados}">
                                    <Entry.Behaviors>
                                    </Entry.Behaviors>
                                    <Entry.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding AbrirSugerenciasMarcaCommand}"/>
                                    </Entry.GestureRecognizers>
                                </Entry>
                                <!-- Lista de sugerencias Marca -->
                                <Frame IsVisible="{Binding MostrarSugerenciasMarca}"
                                   BorderColor="#B00000"
                                   BackgroundColor="White"
                                   Padding="0"
                                   HasShadow="True"
                                   CornerRadius="6"
                                   Margin="0,-2,0,0">
                                    <CollectionView ItemsSource="{Binding MarcasFiltradas}"
                                               SelectionMode="None"
                                               MaximumHeightRequest="200">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="14,10" BackgroundColor="White">
                                                    <Grid.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SeleccionarMarcaCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                    </Grid.GestureRecognizers>
                                                    <Label Text="{Binding .}"
                                                       FontSize="14"
                                                       TextColor="#212121"/>
                                                    <BoxView HeightRequest="1" Color="#F0F0F0"
                                                         VerticalOptions="End"/>
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </Frame>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- â•â• MODELO con autocompletado â•â• -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Grid.Column="0"
                               Text="Modelo:"
                               FontSize="14"
                               FontAttributes="Italic"
                               VerticalOptions="Start"
                               Margin="0,10,0,0"
                               TextColor="#B00000"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="0">
                                <Entry Text="{Binding BusquedaModelo}"
                                   Placeholder="Selecciona la marca primero"
                                   IsReadOnly="{Binding CamposVehiculoBloqueados}">
                                    <Entry.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding AbrirSugerenciasModeloCommand}"/>
                                    </Entry.GestureRecognizers>
                                </Entry>
                                <!-- Lista de sugerencias Modelo -->
                                <Frame IsVisible="{Binding MostrarSugerenciasModelo}"
                                   BorderColor="#B00000"
                                   BackgroundColor="White"
                                   Padding="0"
                                   HasShadow="True"
                                   CornerRadius="6"
                                   Margin="0,-2,0,0">
                                    <CollectionView ItemsSource="{Binding ModelosFiltrados}"
                                               SelectionMode="None"
                                               MaximumHeightRequest="200">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="14,10" BackgroundColor="White">
                                                    <Grid.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SeleccionarModeloCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                    </Grid.GestureRecognizers>
                                                    <Label Text="{Binding .}"
                                                       FontSize="14"
                                                       TextColor="#212121"/>
                                                    <BoxView HeightRequest="1" Color="#F0F0F0"
                                                         VerticalOptions="End"/>
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </Frame>
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Grid.Column="0"
                               Text="VersiÃ³n:"
                               FontSize="14"
                               FontAttributes="Italic"
                               VerticalOptions="Start"
                               Margin="0,10,0,0"
                               TextColor="#B00000"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="0">
                                <Entry Text="{Binding BusquedaVersion}"
                                   Placeholder="Selecciona el modelo primero"
                                   IsReadOnly="{Binding CamposVehiculoBloqueados}">
                                    <Entry.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding AbrirSugerenciasVersionCommand}"/>
                                    </Entry.GestureRecognizers>
                                </Entry>
                                <!-- Lista de sugerencias VersiÃ³n -->
                                <Frame IsVisible="{Binding MostrarSugerenciasVersion}"
                                   BorderColor="#B00000"
                                   BackgroundColor="White"
                                   Padding="0"
                                   HasShadow="True"
                                   CornerRadius="6"
                                   Margin="0,-2,0,0">
                                    <CollectionView ItemsSource="{Binding VersionesFiltradas}"
                                               SelectionMode="None"
                                               MaximumHeightRequest="200">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="14,10" BackgroundColor="White">
                                                    <Grid.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SeleccionarVersionCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                    </Grid.GestureRecognizers>
                                                    <Label Text="{Binding .}"
                                                       FontSize="14"
                                                       TextColor="#212121"/>
                                                    <BoxView HeightRequest="1" Color="#F0F0F0"
                                                         VerticalOptions="End"/>
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </Frame>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- â•â• AÃ‘O con autocompletado  +  PLACA en la misma fila â•â• -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Grid.Column="0" 
                               Text="AÃ±o:"
                               FontSize="14"
                               FontAttributes="Italic"
                               VerticalOptions="Start"
                               Margin="0,10,0,0"
                               TextColor="#B00000"/>

                            <VerticalStackLayout Grid.Column="1" Spacing="0">
                                <Entry Text="{Binding BusquedaAnio}"
                                   Placeholder="2025"
                                   Keyboard="Numeric"
                                   MaxLength="4"
                                   IsReadOnly="{Binding CamposVehiculoBloqueados}">
                                    <Entry.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding AbrirSugerenciasAnioCommand}"/>
                                    </Entry.GestureRecognizers>
                                </Entry>
                                <!-- Lista de sugerencias AÃ±o -->
                                <Frame 
                                IsVisible="{Binding MostrarSugerenciasAnio}"
                                   BorderColor="#B00000"
                                   BackgroundColor="White"
                                   Padding="0"
                                   HasShadow="True"
                                   CornerRadius="6"
                                   Margin="0,-2,0,0">
                                    <CollectionView ItemsSource="{Binding AniosFiltrados}"
                                               SelectionMode="None"
                                               MaximumHeightRequest="120">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
